---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import '../styles/global.css';

import logoImg from '../assets/Logo-removebg-preview.png';
import heroImg from '../assets/gallery/IMG_0958.jpeg';

const imageFiles = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/*.{jpeg,jpg,JPEG,JPG,png,PNG}',
  { eager: true }
);
const galleryImages = Object.values(imageFiles).map(m => m.default);
---

<Layout>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <div class="nav__inner container">
      <a href="#top" class="nav__brand">10 <em>by</em> JEN</a>
      <button class="nav__toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav__links" id="navLinks">
        <li><a href="#services" class="nav__link">Services</a></li>
        <li><a href="#gallery" class="nav__link">Gallery</a></li>
        <li><a href="#about" class="nav__link">About</a></li>
        <li><a href="#contact" class="nav__link">Contact</a></li>
        <li><a href="https://www.vagaro.com/10byjen/book-now" target="_blank" rel="noopener" class="nav__cta">Book Now</a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero" id="top">
    <div class="hero__bg">
      <Image src={heroImg} alt="" width={1400} quality={80} loading="eager" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow">Naples, Florida</span>
      <Image src={logoImg} alt="10 by Jen" class="hero__logo" width={240} quality={90} loading="eager" />
      <p class="hero__tagline">Master of Blonde Hair &amp; Balayage</p>
      <a href="https://www.vagaro.com/10byjen/book-now" target="_blank" rel="noopener" class="btn btn--gold">Book Your Appointment</a>
    </div>
    <a href="#services" class="hero__scroll" aria-label="Scroll to services">
      <svg width="28" height="44" viewBox="0 0 28 44" fill="none">
        <rect x="1" y="1" width="26" height="42" rx="13" stroke="currentColor" stroke-width="1.5"/>
        <circle class="scroll-dot" cx="14" cy="10" r="3" fill="currentColor"/>
      </svg>
    </a>
  </section>

  <!-- MARQUEE TICKER -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      <span>Blonde Specialist</span><span class="dot">◆</span>
      <span>Balayage</span><span class="dot">◆</span>
      <span>Color Certified</span><span class="dot">◆</span>
      <span>Hair Health Specialist</span><span class="dot">◆</span>
      <span>Naples, FL</span><span class="dot">◆</span>
      <span>Elite Artist</span><span class="dot">◆</span>
      <span>Blonde Specialist</span><span class="dot">◆</span>
      <span>Balayage</span><span class="dot">◆</span>
      <span>Color Certified</span><span class="dot">◆</span>
      <span>Hair Health Specialist</span><span class="dot">◆</span>
      <span>Naples, FL</span><span class="dot">◆</span>
      <span>Elite Artist</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- SERVICES -->
  <section class="services section" id="services">
    <div class="container">
      <header class="section-header fade-up">
        <span class="eyebrow">What We Offer</span>
        <h2 class="section-title">The Experience</h2>
        <div class="divider"></div>
      </header>
      <div class="services__grid">
        <article class="service-card fade-up">
          <h3>Blonde &amp; Balayage</h3>
          <p>Signature sun-kissed color, hand-painted for a natural, dimensional finish that grows out beautifully.</p>
        </article>
        <article class="service-card fade-up" style="--delay:.1s">
          <h3>Color &amp; Correction</h3>
          <p>From bold transformations to precision corrections — color certified expertise you can trust.</p>
        </article>
        <article class="service-card fade-up" style="--delay:.2s">
          <h3>Cuts &amp; Styling</h3>
          <p>Precision cuts shaped to your face and lifestyle, with styling education to recreate the look at home.</p>
        </article>
        <article class="service-card fade-up" style="--delay:.3s">
          <h3>Hair Health</h3>
          <p>Restorative treatments and personalized guidance to keep your hair strong, nourished, and thriving.</p>
        </article>
      </div>
      <div class="services__cta fade-up" style="--delay:.2s">
        <a href="https://www.vagaro.com/10byjen/book-now" target="_blank" rel="noopener" class="btn btn--outline">View Services &amp; Pricing on Vagaro</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about section" id="about">
    <div class="container">
      <div class="about__inner">
        <div class="about__media fade-up">
          <!-- Replace the div below with: <Image src={import('../assets/jen.jpeg')} alt="Jen" width={600} /> -->
          <div class="about__photo-placeholder">
            <span>Add a photo<br>of Jen here</span>
          </div>
          <div class="about__badge">
            <span class="badge-top">Elite</span>
            <span class="badge-script">Artist</span>
          </div>
        </div>
        <div class="about__content fade-up" style="--delay:.15s">
          <span class="eyebrow">The Artist</span>
          <h2 class="section-title">Meet Jen</h2>
          <div class="divider divider--left"></div>
          <p>Jen is an elite hair artist and designer — and the proud owner of <strong>10 by Jen Hair Studio LLC</strong> in Naples, FL. With a specialty in blonde hair and balayage, she blends artistry with a deep commitment to hair health to create transformations that are both stunning and sustainable.</p>
          <p>Color certified and passionate about continuing education, Jen brings the highest level of expertise to every guest. Whether you're after a subtle sun-kissed glow or a bold full transformation, she'll craft a result that's uniquely yours.</p>
          <ul class="about__credentials">
            <li>Master of Blonde Hair &amp; Balayage</li>
            <li>Color Certified</li>
            <li>Hair Health Specialist</li>
            <li>Elite Artist &amp; Designer</li>
          </ul>
          <a href="https://www.vagaro.com/10byjen/book-now" target="_blank" rel="noopener" class="btn btn--gold">Book with Jen</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BOOKING / CONTACT -->
  <section class="booking section" id="contact">
    <div class="container">
      <header class="section-header fade-up">
        <span class="eyebrow">Let's Connect</span>
        <h2 class="section-title">Book Your Visit</h2>
        <div class="divider"></div>
      </header>

      <!-- Replace this block with your Vagaro widget embed code when ready -->
      <div class="booking__widget fade-up" style="--delay:.05s">
        <p class="booking__note">Ready for a transformation?</p>
        <a href="https://www.vagaro.com/10byjen/book-now" target="_blank" rel="noopener" class="btn btn--gold btn--lg">Book Online Now</a>
        <p class="booking__or">or call &amp; text</p>
        <a href="tel:+12394807956" class="booking__phone">(239) 480-7956</a>
      </div>

      <div class="contact__grid fade-up" style="--delay:.1s">
        <div class="contact__item">
          <div class="contact__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h4>Location</h4>
          <p>1485 Pine Ridge Rd, Suite 119<br>Naples, FL 33109</p>
          <a href="https://maps.google.com/?q=1485+Pine+Ridge+Rd+Suite+119+Naples+FL" target="_blank" rel="noopener" class="link--gold">Get Directions →</a>
        </div>
        <div class="contact__item">
          <div class="contact__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 3.07 9.8a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 2 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L6.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <h4>Call or Text</h4>
          <a href="tel:+12394807956" class="contact__phone">(239) 480-7956</a>
          <p>By appointment only</p>
        </div>
        <div class="contact__item">
          <div class="contact__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </div>
          <h4>Follow Along</h4>
          <a href="https://www.instagram.com/youre_a_10byjen/" target="_blank" rel="noopener" class="link--gold">Instagram →</a>
          <a href="https://www.facebook.com/merakihobbies/" target="_blank" rel="noopener" class="link--gold">Facebook →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="gallery section" id="gallery">
    <div class="container">
      <header class="section-header fade-up">
        <span class="eyebrow">The Work</span>
        <h2 class="section-title gallery__title">Portfolio</h2>
        <div class="divider"></div>
      </header>
    </div>
    <div class="gallery__grid fade-up" style="--delay:.1s">
      {galleryImages.map((img) => (
        <div class="gallery__item">
          <Image src={img} alt="Hair by Jen" width={600} quality={80} loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer__inner">
        <a href="#top" class="footer__brand">10 <em>by</em> JEN</a>
        <p class="footer__copy">© 2025 10 by Jen Hair Studio LLC · Naples, FL</p>
        <nav class="footer__nav" aria-label="Footer navigation">
          <a href="#services">Services</a>
          <a href="#gallery">Gallery</a>
          <a href="#about">About</a>
          <a href="https://www.vagaro.com/10byjen/book-now" target="_blank" rel="noopener">Book Now</a>
          <a href="https://www.instagram.com/youre_a_10byjen/" target="_blank" rel="noopener">Instagram</a>
          <a href="https://www.facebook.com/merakihobbies/" target="_blank" rel="noopener">Facebook</a>
        </nav>
      </div>
    </div>
  </footer>

</Layout>
